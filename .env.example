# Copy this file to .env.local and fill in real values locally.
# Never commit .env.local or any file containing real secrets.

# Firebase web app configuration
VITE_FIREBASE_API_KEY="replace-with-your-rotated-firebase-web-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
VITE_FIREBASE_APP_ID="your-firebase-app-id"
VITE_FIREBASE_MEASUREMENT_ID="your-measurement-id"

# GEMINI_API_KEY: Required only if Gemini AI API calls are added.
# AI Studio can inject this at runtime from user secrets.
GEMINI_API_KEY="replace-with-your-gemini-api-key-if-needed"

# APP_URL: The URL where this applet is hosted.
APP_URL="replace-with-your-app-url"
